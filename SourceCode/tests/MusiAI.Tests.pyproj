<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>AB9FAE38-5F6A-5E1B-C5F6-7B4D9B2C3E4F</ProjectGuid>
    <ProjectHome>..</ProjectHome>
    <StartupFile>tests\test_runner_ui.py</StartupFile>
    <SearchPath>.</SearchPath>
    <WorkingDirectory>..</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>MusiAI.Tests</Name>
    <RootNamespace>MusiAI.Tests</RootNamespace>
    <InterpreterId>MSBuild|pythonENV|$(MSBuildProjectFullPath)</InterpreterId>
    <TestFramework>unittest</TestFramework>
    <UnitTestPattern>test_*.py</UnitTestPattern>
    <UnitTestRootDirectory>tests</UnitTestRootDirectory>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="tests\__init__.py" />
    <Compile Include="tests\run_tests.py" />
    <Compile Include="tests\test_runner_ui.py" />
    <!-- data -->
    <Compile Include="tests\data\__init__.py" />
    <Compile Include="tests\data\test_model.py" />
    <Compile Include="tests\data\test_midi.py" />
    <Compile Include="tests\data\test_musicxml.py" />
    <!-- audio -->
    <Compile Include="tests\audio\__init__.py" />
    <Compile Include="tests\audio\test_audio.py" />
    <!-- longrunner (slow tests, >3s) -->
    <Compile Include="tests\longrunner\__init__.py" />
    <Compile Include="tests\longrunner\test_audio_features.py" />
    <Compile Include="tests\longrunner\test_audio_playback.py" />
    <Compile Include="tests\longrunner\test_detection_pipelines.py" />
    <!-- ui -->
    <Compile Include="tests\ui\__init__.py" />
    <Compile Include="tests\ui\test_notation.py" />
    <Compile Include="tests\ui\test_notation_and_import.py" />
    <Compile Include="tests\ui\test_selection_copypaste.py" />
    <Compile Include="tests\ui\test_tabs_and_pdf.py" />
    <Compile Include="tests\ui\test_ui_workflows.py" />
    <!-- integration -->
    <Compile Include="tests\integration\__init__.py" />
    <Compile Include="tests\integration\test_integration.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="tests\" />
    <Folder Include="tests\data\" />
    <Folder Include="tests\audio\" />
    <Folder Include="tests\longrunner\" />
    <Folder Include="tests\ui\" />
    <Folder Include="tests\integration\" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="..\..\pythonENV\">
      <Id>pythonENV</Id>
      <Version>3.14</Version>
      <Description>MusiAI Python 3.14 (venv)</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>
