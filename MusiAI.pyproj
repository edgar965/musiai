<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>DA8FAE38-4F5A-4D0A-B4E5-6A3C8A1B2D3E</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>main.py</StartupFile>
    <SearchPath>.</SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>MusiAI</Name>
    <RootNamespace>MusiAI</RootNamespace>
    <InterpreterId>MSBuild|pythonENV|$(MSBuildProjectFullPath)</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="main.py" />
    <!-- Model -->
    <Compile Include="musiai\__init__.py" />
    <Compile Include="musiai\model\__init__.py" />
    <Compile Include="musiai\model\AudioTrack.py" />
    <Compile Include="musiai\model\Expression.py" />
    <Compile Include="musiai\model\Measure.py" />
    <Compile Include="musiai\model\Note.py" />
    <Compile Include="musiai\model\Part.py" />
    <Compile Include="musiai\model\Piece.py" />
    <Compile Include="musiai\model\Project.py" />
    <Compile Include="musiai\model\Tempo.py" />
    <Compile Include="musiai\model\TimeSignature.py" />
    <!-- MIDI -->
    <Compile Include="musiai\midi\__init__.py" />
    <Compile Include="musiai\midi\MidiImporter.py" />
    <Compile Include="musiai\midi\MidiExporter.py" />
    <Compile Include="musiai\midi\MidiKeyboard.py" />
    <Compile Include="musiai\midi\MidiMapping.py" />
    <Compile Include="musiai\midi\MusicXmlImporterCompat.py" />
    <!-- MusicXML -->
    <Compile Include="musiai\musicXML\__init__.py" />
    <Compile Include="musiai\musicXML\MusicXmlConstants.py" />
    <Compile Include="musiai\musicXML\PitchParser.py" />
    <Compile Include="musiai\musicXML\NoteParser.py" />
    <Compile Include="musiai\musicXML\MeasureParser.py" />
    <Compile Include="musiai\musicXML\MusicXmlImporter.py" />
    <Compile Include="musiai\musicXML\MusicXmlExporter.py" />
    <!-- Audio -->
    <Compile Include="musiai\audio\__init__.py" />
    <Compile Include="musiai\audio\AudioPlayer.py" />
    <Compile Include="musiai\audio\BasicPitchDetector.py" />
    <Compile Include="musiai\audio\DemucsDetector.py" />
    <Compile Include="musiai\audio\FluidSynthPlayer.py" />
    <Compile Include="musiai\audio\MidiPortPlayer.py" />
    <Compile Include="musiai\audio\PitchDetector.py" />
    <Compile Include="musiai\audio\PlaybackEngine.py" />
    <Compile Include="musiai\audio\SoundFontPlayer.py" />
    <Compile Include="musiai\audio\Transport.py" />
    <!-- Notation -->
    <Compile Include="musiai\notation\__init__.py" />
    <Compile Include="musiai\notation\ClefItem.py" />
    <Compile Include="musiai\notation\ColorScheme.py" />
    <Compile Include="musiai\notation\CursorItem.py" />
    <Compile Include="musiai\notation\CurveItem.py" />
    <Compile Include="musiai\notation\DurationItem.py" />
    <Compile Include="musiai\notation\MeasureRenderer.py" />
    <Compile Include="musiai\notation\NotationScene.py" />
    <Compile Include="musiai\notation\NoteItem.py" />
    <Compile Include="musiai\notation\PlayheadItem.py" />
    <Compile Include="musiai\notation\StaffRenderer.py" />
    <Compile Include="musiai\notation\TempoMarking.py" />
    <Compile Include="musiai\notation\TimeSignatureItem.py" />
    <Compile Include="musiai\notation\WaveformItem.py" />
    <Compile Include="musiai\notation\ZigzagItem.py" />
    <!-- PDF -->
    <Compile Include="musiai\pdf\__init__.py" />
    <Compile Include="musiai\pdf\PdfEngineConfig.py" />
    <Compile Include="musiai\pdf\PdfImportWorker.py" />
    <Compile Include="musiai\pdf\PdfExportWorker.py" />
    <Compile Include="musiai\pdf\AudiverisAdapter.py" />
    <Compile Include="musiai\pdf\OemerAdapter.py" />
    <Compile Include="musiai\pdf\Pdf2MusicxmlAdapter.py" />
    <Compile Include="musiai\pdf\LilypondAdapter.py" />
    <Compile Include="musiai\pdf\MusescoreAdapter.py" />
    <Compile Include="musiai\pdf\ReportlabAdapter.py" />
    <!-- UI -->
    <Compile Include="musiai\ui\__init__.py" />
    <Compile Include="musiai\ui\AboutDialog.py" />
    <Compile Include="musiai\ui\DocumentTab.py" />
    <Compile Include="musiai\ui\MainWindow.py" />
    <Compile Include="musiai\ui\MeasureInputDialog.py" />
    <Compile Include="musiai\ui\MidiDeviceDialog.py" />
    <Compile Include="musiai\ui\NotationView.py" />
    <Compile Include="musiai\ui\PropertiesPanel.py" />
    <Compile Include="musiai\ui\SettingsDialog.py" />
    <Compile Include="musiai\ui\SoundfontDialog.py" />
    <Compile Include="musiai\ui\StatusBar.py" />
    <Compile Include="musiai\ui\TabWidget.py" />
    <Compile Include="musiai\ui\Toolbar.py" />
    <Compile Include="musiai\ui\ZoomWidget.py" />
    <!-- Controller -->
    <Compile Include="musiai\controller\__init__.py" />
    <Compile Include="musiai\controller\AppController.py" />
    <Compile Include="musiai\controller\EditController.py" />
    <Compile Include="musiai\controller\FileController.py" />
    <Compile Include="musiai\controller\RecordingController.py" />
    <!-- Util -->
    <Compile Include="musiai\util\__init__.py" />
    <Compile Include="musiai\util\Constants.py" />
    <Compile Include="musiai\util\LoggingConfig.py" />
    <Compile Include="musiai\util\PitchUtils.py" />
    <Compile Include="musiai\util\SignalBus.py" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="requirements.txt" />
    <Content Include="CLAUDE.md" />
    <Content Include="media\Stimmen\instruments.json" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="musiai\" />
    <Folder Include="musiai\model\" />
    <Folder Include="musiai\midi\" />
    <Folder Include="musiai\musicXML\" />
    <Folder Include="musiai\audio\" />
    <Folder Include="musiai\notation\" />
    <Folder Include="musiai\pdf\" />
    <Folder Include="musiai\ui\" />
    <Folder Include="musiai\controller\" />
    <Folder Include="musiai\util\" />
    <Folder Include="media\" />
    <Folder Include="media\music\" />
    <Folder Include="media\mp3\" />
    <Folder Include="media\pdf\" />
    <Folder Include="media\projects\" />
    <Folder Include="media\soundfonts\" />
    <Folder Include="media\Stimmen\" />
    <Folder Include="Recherche\" />
    <Folder Include="logs\" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="pythonENV\">
      <Id>pythonENV</Id>
      <Version>3.14</Version>
      <Description>MusiAI Python 3.14 (venv)</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>
